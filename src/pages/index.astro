---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import RecentPosts from "../components/RecentPosts.astro";
import avatar from "../assets/avatar.jpg";
import EmailIcon from "../icons/EmailIcon.astro";
import GitHubIcon from "../icons/GitHubIcon.astro";

const headingClasses =
  "text-2xl md:text-3xl font-semibold mb-8 md:mb-16 text-center";
const sectionClasses = "mb-24 md:mb-44";
---

<Layout>
  <section
    class:list={[
      sectionClasses,
      "flex flex-col items-center mt-24 md:mt-32",
    ]}
  >
    <Image
      src={avatar}
      alt="Andy Yoon"
      class="h-40 w-40 md:h-48 md:w-48 rounded-full shadow-md shadow-stone-400 dark:shadow-stone-900 mb-6"
    />
    <h2 class="text-2xl md:text-3xl font-semibold mb-10">Hi, I&rsquo;m Andy!</h2>
    <h3 class="text-lg md:text-xl text-center mb-4">
      Cultivating high quality work <span class="inline-block">&amp; delighting in the process.</span>
    </h3>
    <h3 class="text-lg md:text-xl text-center">
      Lead Frontend Engineer at
      <a class="underline" href="https://www.openevidence.com" target="_blank"
        >OpenEvidence</a
      >.
    </h3>
  </section>

  <section class:list={[sectionClasses, "md:text-lg flex flex-col gap-4"]}>
    <p>
      I love building intuitive products to empower people to make wiser
      decisions.
    </p>
    <p>
      I'm on a journey of self-discovery and learning. I hope you find insights
      here that help you in your own life.
    </p>
    <p>
      Read about
      <a class="underline" href="/now">what I'm doing now</a>.
    </p>
  </section>

  <section id="blog" class={`${sectionClasses} scroll-mt-18`}>
    <h2 class={headingClasses}>Blog</h2>
    <RecentPosts />
  </section>

  <section id="contact" class={sectionClasses}>
    <h2 class={headingClasses}>Say Hello</h2>
    <ul
      class="flex flex-col items-center md:flex-row gap-8 md:gap-16 md:justify-center"
    >
      <li class="flex items-center gap-4">
        <EmailIcon />
        <a class="underline md:text-lg" href="mailto:hello@andyyoon.co"
          >hello@andyyoon.co</a
        >
      </li>
      <li class="flex items-center gap-4">
        <GitHubIcon />
        <a class="underline md:text-lg" href="https://www.github.com/andyyoon2"
          >andyyoon2</a
        >
      </li>
    </ul>
  </section>
</Layout>
