---
import Signature from "./Signature.astro";
const today = new Date();
---

<footer class="text-center p-4 mt-16">
  <p
    class="text-secondary flex justify-center items-center gap-2"
  >
    <span class="text-secondary/85"><Signature /></span>
    <span class="ml-2">&copy;</span>
    <span>{today.getFullYear()}</span>
  </p>
</footer>
